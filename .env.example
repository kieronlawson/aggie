# Copy to .env for local runs: set -a; source .env; set +a
# All of these live in GitHub repository secrets for Actions runs.
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
TURBOPUFFER_API_KEY=
FIRECRAWL_API_KEY=
SLACK_BOT_TOKEN=

# Non-secret configuration (defaults shown)
# TurboPuffer region host prefix, e.g. gcp-us-east4 or aws-us-east-1
TURBOPUFFER_REGION=gcp-us-east4
# staging routes ALL output (digests + alerts) to #intel-staging.
# Set to production at the phase-3 gate to cut over to real channels.
OUTPUT_STAGE=staging
